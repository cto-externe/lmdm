# Go
/bin/
/dist/
*.exe
*.test
*.out
coverage.out
coverage.html

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets / local
.env
.env.local
*.pem
*.key

# Docker / data locaux
.data/

# Local JWT / AES / TLS key material generated by `make keys` or
# `lmdm-keygen`. The directory itself is tracked (via .gitkeep) so the
# server's default paths resolve; only its contents are ignored.
/deploy/secrets/*
!/deploy/secrets/.gitkeep

# Git worktrees
.worktrees/

# Claude Code local settings (IDE-specific, per-user)
.claude/

# Local-only working notes (architecture spec, protocol doc)
/ARCHITECTURE_SPEC_V1.md
/Protocol-Buffer-Definitions.md

# Implementation plans (internal tooling, not distributed)
/.plans/

# Dev guide (local-only, was previously committed then untracked)
/docs/DEVELOPMENT.md

# Compiled binaries at repo root (from `go build ./cmd/...` without -o)
/lmdm-agent
/lmdm-server
/lmdm-token
/lmdm-profile

# Tailwind build output (regenerated from tailwind.css)
/internal/webui/assets/app.css
/bin/tailwindcss

# Templ generated Go files
/internal/webui/**/*_templ.go
